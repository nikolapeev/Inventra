@model Inventra.Core.ViewModels.Products.ProductDetailsViewModel

@{
    ViewData["Title"] = "Product Details";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Product Details</h1>
        <div>
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">Edit</a>
            <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="row g-0">
            <div class="col-md-4 bg-light text-center d-flex align-items-center justify-content-center p-3">
                @if (!string.IsNullOrEmpty(Model.ImageURL))
                {
                    <img src="@Model.ImageURL" class="img-fluid rounded shadow-sm" alt="@Model.Name" style="max-height: 300px;">
                }
                else
                {
                    <div class="text-muted">
                        <i class="bi bi-image" style="font-size: 4rem;"></i>
                        <p>No Image Available</p>
                    </div>
                }
            </div>

            <div class="col-md-8">
                <div class="card-body">
                    <h4 class="card-title text-primary">@Model.Name</h4>
                    <p class="text-muted small">ID: @Model.Id</p>
                    <hr />

                    <dl class="row">
                        <dt class="col-sm-4">Category</dt>
                        <dd class="col-sm-8">@Model.CategoryName</dd>

                        <dt class="col-sm-4">Supplier</dt>
                        <dd class="col-sm-8">@Model.SupplierName</dd>

                        <dt class="col-sm-4">Price</dt>
                        <dd class="col-sm-8 fw-bold text-success">@Model.Price.ToString("C", System.Globalization.CultureInfo.CreateSpecificCulture("fr-FR"))</dd>

                        <dt class="col-sm-4">In Stock</dt>
                        <dd class="col-sm-8">
                            <span class="badge @(Model.StockQuantity > 10 ? "bg-success" : "bg-danger")">
                                @Model.StockQuantity units
                            </span>
                        </dd>

                        <dt class="col-sm-4">Location</dt>
                        <dd class="col-sm-8 text-uppercase">@Model.WarehouseLocationId</dd>

                        <dt class="col-sm-4">Batch #</dt>
                        <dd class="col-sm-8"><code>@Model.BatchNumber</code></dd>

                        <dt class="col-sm-4">Description</dt>
                        <dd class="col-sm-8">@Model.Description</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>