@model Inventra.Core.ViewModels.Products.ProductDetailsViewModel

@{
    ViewData["Title"] = "Product Details";
}

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <a asp-action="Index" class="text-decoration-none text-muted mb-2 d-inline-block">
            <i class="bi bi-arrow-left me-1"></i> Back to Products
        </a>
        <h1 class="h3 text-dark fw-bold">Product Information</h1>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary shadow-sm rounded-3">
            <i class="bi bi-pencil me-1"></i> Edit Product
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-4">
        <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
            <div class="bg-light d-flex justify-content-center align-items-center" style="height: 250px; border-bottom: 1px solid #dee2e6;">
                @if (!string.IsNullOrEmpty(Model.ImageURL))
                {
                    <img src="@Model.ImageURL" alt="@Model.Name" class="img-fluid object-fit-contain w-100 h-100" onerror="this.outerHTML='<i class=\'bi bi-box-seam text-secondary\' style=\'font-size: 5rem;\'></i>';" />
                }
                else
                {
                    <i class="bi bi-box-seam text-secondary" style="font-size: 5rem;"></i>
                }
            </div>
            <div class="card-body p-4">
                <h4 class="fw-bold text-dark mb-2">@Html.DisplayFor(model => model.Name)</h4>
                
                <p class="text-muted mt-3 mb-0" style="white-space: pre-wrap;">@Html.DisplayFor(model => model.Description)</p>
            </div>
        </div>
    </div>

    <div class="col-xl-8">
        <div class="row g-4 h-100">
            <div class="col-sm-6">
                <div class="card border-0 shadow-sm rounded-4 border-start border-success border-4 h-100">
                    <div class="card-body p-4">
                        <div class="text-xs fw-bold text-success text-uppercase mb-1">Pricing</div>
                        <div class="h3 mb-0 fw-bold text-dark">$@Html.DisplayFor(model => model.Price)</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6">
                <div class="card border-0 shadow-sm rounded-4 border-start border-primary border-4 h-100">
                    <div class="card-body p-4">
                        <div class="text-xs fw-bold text-primary text-uppercase mb-1">Current Stock</div>
                        <div class="h3 mb-0 fw-bold text-dark">
                            @Html.DisplayFor(model => model.StockQuantity)
                            <small class="text-muted fs-6 fw-normal">Units</small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-white border-bottom py-3 px-4">
                        <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-upc-scan text-primary me-2"></i>Inventory Tracking</h5>
                    </div>
                    <div class="card-body p-4">
                        <dl class="row mb-0 g-3">
                            <dt class="col-sm-4 text-muted fw-normal">Warehouse Location ID</dt>
                            <dd class="col-sm-8 fw-bold text-dark">
                                <span class="badge bg-light text-dark border border-secondary px-2 py-1">@Html.DisplayFor(model => model.WarehouseLocationId)</span>
                            </dd>
                            
                            <div class="col-12"><hr class="my-1 border-light"></div>

                            <dt class="col-sm-4 text-muted fw-normal">Batch Number</dt>
                            <dd class="col-sm-8 fw-bold text-dark">@Html.DisplayFor(model => model.BatchNumber)</dd>
                            
                            <div class="col-12"><hr class="my-1 border-light"></div>

                            <dt class="col-sm-4 text-muted fw-normal">Category ID</dt>
                            <dd class="col-sm-8 fw-bold text-dark">@Html.DisplayFor(model => model.CategoryName)</dd>
                            
                            <div class="col-12"><hr class="my-1 border-light"></div>

                            <dt class="col-sm-4 text-muted fw-normal">Supplier ID</dt>
                            <dd class="col-sm-8 fw-bold text-dark">@Html.DisplayFor(model => model.SupplierName)</dd>
                            
                            <div class="col-12"><hr class="my-1 border-light"></div>

                            <dt class="col-sm-4 text-muted fw-normal">Added By</dt>
                            <dd class="col-sm-8 fw-bold text-dark">
                                <i class="bi bi-person-circle text-secondary me-1"></i> @Html.DisplayFor(model => model.AddedBy)
                            </dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>