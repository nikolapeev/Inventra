@model Inventra.Core.ViewModels.Products.ProductEditViewModel

@{
    ViewData["Title"] = "Edit Product";
}

<div class="mb-4">
    <a asp-action="Index" class="text-decoration-none text-muted mb-2 d-inline-block">
        <i class="bi bi-arrow-left me-1"></i> Back to Products
    </a>
    <h1 class="h3 text-dark fw-bold">Edit Product</h1>
    <p class="text-muted">Update product details, pricing, and inventory tracking.</p>
</div>

<div class="row">
    <div class="col-xl-10">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 p-md-5">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 rounded p-2 bg-danger bg-opacity-10" style="display: none;"></div>
                    
                    <input type="hidden" asp-for="Id" />

                    <h5 class="text-primary mb-3"><i class="bi bi-box-seam me-2"></i>Basic Information</h5>
                    <div class="row g-4 mb-4">
                        <div class="col-md-12">
                            <label asp-for="Name" class="form-label fw-bold text-dark">Product Name <span class="text-danger">*</span></label>
                            <div class="input-group input-group-lg shadow-sm rounded-3">
                                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-tag"></i></span>
                                <input asp-for="Name" class="form-control border-start-0 ps-0" placeholder="Product name (3-500 characters)" />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CategoryId" class="form-label fw-bold text-dark">Category <span class="text-danger">*</span></label>
                            <div class="input-group shadow-sm rounded-3">
                                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-bookmarks"></i></span>
                                <select asp-for="CategoryId" class="form-select border-start-0 ps-0" asp-items="ViewBag.CategoryId"></select>
                            </div>
                            <span asp-validation-for="CategoryId" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="SupplierId" class="form-label fw-bold text-dark">Supplier <span class="text-danger">*</span></label>
                            <div class="input-group shadow-sm rounded-3">
                                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-truck"></i></span>
                                <select asp-for="SupplierId" class="form-select border-start-0 ps-0" asp-items="ViewBag.SupplierId"></select>
                            </div>
                            <span asp-validation-for="SupplierId" class="text-danger small mt-1 d-block"></span>
                        </div>
                        
                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-bold text-dark">Description <span class="text-danger">*</span></label>
                            <textarea asp-for="Description" class="form-control shadow-sm rounded-3" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <hr class="my-4 border-light" />
                    <h5 class="text-primary mb-3"><i class="bi bi-upc-scan me-2"></i>Stock & Tracking</h5>

                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <label asp-for="Price" class="form-label fw-bold text-dark">Price <span class="text-danger">*</span></label>
                            <div class="input-group shadow-sm rounded-3">
                                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-currency-dollar"></i></span>
                                <input asp-for="Price" type="number" step="0.01" class="form-control border-start-0 ps-0" />
                            </div>
                            <span asp-validation-for="Price" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="StockQuantity" class="form-label fw-bold text-dark">Stock Quantity <span class="text-danger">*</span></label>
                            <div class="input-group shadow-sm rounded-3">
                                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-123"></i></span>
                                <input asp-for="StockQuantity" type="number" class="form-control border-start-0 ps-0" />
                            </div>
                            <span asp-validation-for="StockQuantity" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="BatchNumber" class="form-label fw-bold text-dark">Batch Number <span class="text-danger">*</span></label>
                            <div class="input-group shadow-sm rounded-3">
                                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-hash"></i></span>
                                <input asp-for="BatchNumber" class="form-control border-start-0 ps-0" />
                            </div>
                            <span asp-validation-for="BatchNumber" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="WarehouseLocationId" class="form-label fw-bold text-dark">Warehouse Location ID <span class="text-danger">*</span></label>
                            <div class="input-group shadow-sm rounded-3">
                                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-geo-fill"></i></span>
                                <input asp-for="WarehouseLocationId" class="form-control border-start-0 ps-0" style="text-transform: uppercase;" />
                            </div>
                            <span asp-validation-for="WarehouseLocationId" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-8">
                            <label asp-for="ImageURL" class="form-label fw-bold text-dark">Image URL <span class="text-danger">*</span></label>
                            <div class="input-group shadow-sm rounded-3">
                                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-image"></i></span>
                                <input asp-for="ImageURL" class="form-control border-start-0 ps-0" />
                            </div>
                            <span asp-validation-for="ImageURL" class="text-danger small mt-1 d-block"></span>
                        </div>

                    <hr class="my-4 text-muted" />

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-light px-4 rounded-3">Cancel</a>
                        <button type="submit" class="btn btn-primary px-4 rounded-3 shadow-sm">
                            <i class="bi bi-save me-1"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function () {
            if ($(".validation-summary-errors").length) {
                $(".text-danger.mb-3").show();
            }
        });
    </script>
}