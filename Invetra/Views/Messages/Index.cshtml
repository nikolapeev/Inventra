@model IEnumerable<Inventra.Core.ViewModels.Messages.MessageIndexViewModel>

@{
    ViewData["Title"] = "Message Board";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Message Board</h1>
    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="bi bi-plus-circle"></i> Post New Message
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-10 col-lg-8">
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5 border rounded bg-light shadow-sm">
                <i class="bi bi-chat-square-text fs-1"></i>
                <p class="mt-3 fs-5">No messages found.</p>
            </div>
        }
        
        @foreach (var item in Model.OrderByDescending(m => m.CreatedAt))
        {
            <div class="card shadow-sm mb-4 border-0 border-start border-4 border-primary">
                <div class="card-header bg-white border-bottom-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center">
                        <div class="bg-secondary text-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 40px; height: 40px;">
                            <i class="bi bi-person fs-5"></i>
                        </div>
                        <div>
                            <h6 class="mb-0 fw-bold">@item.CreatedBy</h6>
                            <small class="text-muted">@item.CreatedAt.ToString("g")</small>
                        </div>
                    </div>
                    @{
                        if (item.Type.ToString() == "Crucial")
                        {
                            <span class="badge bg-danger text-white rounded-pill">@item.Type</span>
                        }
                        else if (item.Type.ToString() == "Info")
                        {
                            <span class="badge bg-success text-white rounded-pill">@item.Type</span>
                        }
                        else if (item.Type.ToString() == "Misc")
                        {
                            <span class="badge bg-info text-white rounded-pill">@item.Type</span>
                        }
                    }

                    
                </div>
                
                <div class="card-body py-3">
                    <p class="card-text fs-5 mb-0" style="white-space: pre-wrap;">@item.Content</p>
                </div>
                
                <div class="card-footer bg-white border-top-0 text-end pb-3">
                    @if (item.CreatedBy == User.Identity?.Name||User.IsInRole("Administrator"))
                    {
                        <div class="btn-group" role="group">
                            <form asp-action="Delete" method="post" asp-route-id="@item.Id" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-danger ms-1" onclick="return confirm('Are you sure you want to delete this message?');">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>