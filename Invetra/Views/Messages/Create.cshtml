@model Inventra.Core.ViewModels.Messages.MessageCreateViewModel
@using Inventra.Data.Enums

@{
    ViewData["Title"] = "Post a Message";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <h2 class="mb-4">Post a Message</h2>
        
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row mb-3">
                        <div class="col-md-6 form-group">
                            <label asp-for="CreatedBy" class="control-label fw-bold text-muted mb-1">Author Name</label>
                            <input asp-for="CreatedBy" class="form-control" placeholder="Enter your name" />
                            <span asp-validation-for="CreatedBy" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 form-group">
                            <label asp-for="Type" class="control-label fw-bold text-muted mb-1">Message Category</label>
                            <select asp-for="Type" class="form-select" asp-items="Html.GetEnumSelectList<MessageType>()">
                                <option value="">-- Select Category --</option>
                            </select>
                            <span asp-validation-for="Type" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Content" class="control-label fw-bold text-muted mb-1">Message Content</label>
                        <textarea asp-for="Content" class="form-control" rows="5" placeholder="Write something... (10 to 50 characters)"></textarea>
                        <span asp-validation-for="Content" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                        <a asp-action="Index" class="btn btn-light me-2">Cancel</a>
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-send me-1"></i> Post Message
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}