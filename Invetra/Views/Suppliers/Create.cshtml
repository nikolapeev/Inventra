@model Inventra.Core.ViewModels.Suppliers.SupplierCreateViewModel

@{
    ViewData["Title"] = "Add Supplier";
}

<div class="mb-4">
    <a asp-action="Index" class="text-decoration-none text-muted mb-2 d-inline-block">
        <i class="bi bi-arrow-left me-1"></i> Back to Suppliers
    </a>
    <h1 class="h3 text-dark fw-bold">Add New Supplier</h1>
    <p class="text-muted">Enter the details for your new vendor below.</p>
</div>

<div class="row">
    <div class="col-lg-10 col-xl-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 p-md-5">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 rounded p-2 bg-danger bg-opacity-10" style="display: none;"></div>
                    
                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label fw-bold text-dark">Company Name <span class="text-danger">*</span></label>
                            <div class="input-group input-group-lg shadow-sm rounded-3">
                                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-building"></i></span>
                                <input asp-for="Name" class="form-control border-start-0 ps-0" placeholder="e.g. Global Tech Supplies" />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-bold text-dark">Email Address <span class="text-danger">*</span></label>
                            <div class="input-group input-group-lg shadow-sm rounded-3">
                                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-envelope"></i></span>
                                <input asp-for="Email" class="form-control border-start-0 ps-0" placeholder="contact@company.com" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label fw-bold text-dark">Phone Number <span class="text-danger">*</span></label>
                            <div class="input-group input-group-lg shadow-sm rounded-3">
                                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-telephone"></i></span>
                                <input asp-for="PhoneNumber" class="form-control border-start-0 ps-0" placeholder="08xxxxxxxx" />
                            </div>
                            <span asp-validation-for="PhoneNumber" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="EIK" class="form-label fw-bold text-dark">EIK</label>
                            <div class="input-group shadow-sm rounded-3">
                                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-clipboard2"></i></span>
                                <input asp-for="EIK" class="form-control border-start-0 ps-0" />
                            </div>
                            <span asp-validation-for="EIK" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <hr class="my-4 text-muted" />

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-light px-4 rounded-3">Cancel</a>
                        <button type="submit" class="btn btn-primary px-4 rounded-3 shadow-sm">
                            <i class="bi bi-check-lg me-1"></i> Create Supplier
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    
    <script>
        $(document).ready(function () {
            if ($(".validation-summary-errors").length) {
                $(".text-danger.mb-3").show();
            }
        });
    </script>
}