@model IEnumerable<Inventra.Core.ViewModels.Suppliers.SupplierIndexViewModel>

@{
    ViewData["Title"] = "Suppliers";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h1 class="h3 mb-1 text-dark fw-bold">Suppliers</h1>
        <p class="text-muted mb-0">Manage your vendors and supply chain contacts.</p>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-primary shadow-sm rounded-3">
            <i class="bi bi-plus-lg me-1"></i> Add Supplier
        </a>
    </div>
</div>

<!-- Data Card -->
<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4 py-3">Supplier Name</th>
                        <th class="py-3">Phone</th>
                        <th class="py-3">EIK</th>
                        <th class="py-3">Email</th>
                        <th class="text-end pe-4 py-3" style="width: 15%;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-truck fs-2 d-block mb-2"></i>
                                No suppliers found. Click "Add Supplier" to create one.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark py-3">
                                    <div class="d-flex align-items-center">
                                        <!-- Using the warning color for suppliers based on the dashboard -->
                                        <div class="bg-warning bg-opacity-10 text-warning rounded d-flex justify-content-center align-items-center me-3" style="width: 35px; height: 35px;">
                                            <i class="bi bi-building"></i>
                                        </div>
                                        @Html.DisplayFor(modelItem => item.Name)
                                    </div>
                                </td>
                                <td class="py-3 text-muted">
                                    <i class="bi bi-telephone text-secondary me-1"></i> @Html.DisplayFor(modelItem => item.PhoneNumber)
                                </td>
                                <td class="py-3 text-muted">
                                    <i class="text-decoration-none"></i> @Html.DisplayFor(modelItem => item.EIK)
                                </td>
                                <td class="py-3 text-muted">
                                    <a href="mailto:@item.Email" class="text-decoration-none">@Html.DisplayFor(modelItem => item.Email)</a>
                                </td>
                                <td class="text-end pe-4 py-3">
                                    <div class="btn-group btn-group-sm shadow-sm" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.SupplierId" class="btn btn-outline-primary" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.SupplierId" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this supplier?');">
                                            <button type="submit" class="btn btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>