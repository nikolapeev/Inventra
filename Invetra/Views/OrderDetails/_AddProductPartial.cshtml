@using Inventra.Core.ViewModels.OrderDetails
@model OrderDetailsCreateViewModel

<div class="modal-header border-bottom-0 pb-0">
    <h5 class="modal-title fw-bold text-dark">Add Product to Order</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<form asp-controller="OrderDetails" asp-action="Create" method="post">
    <div class="modal-body py-4">
        <p class="text-muted small mb-3">Select an available item from the inventory. It will be added with a quantity of 1.</p>
        
        <input type="hidden" asp-for="OrderId" />
        
        <div class="form-group mb-2">
            <label asp-for="ProductId" class="form-label fw-bold text-dark">Product <span class="text-danger">*</span></label>
            <div class="input-group input-group-lg shadow-sm rounded-3">
                <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-box"></i></span>
                <select asp-for="ProductId" class="form-select border-start-0 ps-0" asp-items="ViewBag.ProductId">
                    <option value="">-- Select Product --</option>
                </select>
            </div>
            <span asp-validation-for="ProductId" class="text-danger small mt-1 d-block"></span>
        </div>
    </div>
    
    <div class="modal-footer border-top-0 pt-0">
        <button type="button" class="btn btn-light rounded-3 px-4" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary rounded-3 px-4 shadow-sm"><i class="bi bi-plus-circle me-1"></i> Add Product</button>
    </div>
</form>

<partial name="_ValidationScriptsPartial" />