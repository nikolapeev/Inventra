@model Inventra.Core.ViewModels.Home.HomeStatsViewModel

@{
    ViewData["Title"] = "Home Page";
}

@if (User.Identity?.IsAuthenticated == true && Model != null)
{

    <div class="container-fluid py-4">
        <div class="row mb-4">
            <div class="col-12">
                <h1 class="h3 mb-1 text-dark fw-bold">Inventory Dashboard</h1>
                <p class="text-muted">Overview of business performance and product movement.</p>
            </div>
        </div>

        <div class="row g-4 mb-4">
            
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm rounded-4 h-100 border-start border-danger border-4">
                    <div class="card-header bg-transparent border-0 pt-4 px-4">
                        <h5 class="fw-bold mb-0 text-danger">
                            <i class="bi bi-exclamation-octagon-fill me-2"></i>Crucial Alerts
                        </h5>
                    </div>
                    <div class="card-body px-4 pb-4">
                        @if (Model.CrucialMessages.Any())
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var msg in Model.CrucialMessages)
                                {
                                    <div class="list-group-item border-0 px-0 py-3 mb-2 bg-transparent border-bottom">
                                        <div class="d-flex w-100 justify-content-between align-items-center mb-2">
                                            <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-2">Crucial</span>
                                            <small class="text-muted fw-medium"><i class="bi bi-clock me-1"></i>@msg.CreatedAt.ToString("dd MMM, HH:mm")</small>
                                        </div>
                                        <p class="mb-2 text-dark fw-medium">@msg.Content</p>
                                        <small class="text-muted"><i class="bi bi-person me-1"></i>Posted by @msg.CreatedBy</small>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-4">
                                <i class="bi bi-check-circle text-success fs-2 d-block mb-2"></i>
                                <p class="text-muted small mb-0">System is stable. No crucial alerts.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card border-0 shadow-sm rounded-4 h-100 border-start border-info border-4">
                    <div class="card-header bg-transparent border-0 pt-4 px-4">
                        <h5 class="fw-bold mb-0 text-info">
                            <i class="bi bi-info-circle-fill me-2"></i>System Information
                        </h5>
                    </div>
                    <div class="card-body px-4 pb-4">
                        @if (Model.InfoMessages.Any())
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var msg in Model.InfoMessages)
                                {
                                    <div class="list-group-item border-0 px-0 py-3 mb-2 bg-transparent border-bottom">
                                        <div class="d-flex w-100 justify-content-between align-items-center mb-2">
                                            <span class="badge bg-info bg-opacity-10 text-info rounded-pill px-2">Info</span>
                                            <small class="text-muted fw-medium"><i class="bi bi-clock me-1"></i>@msg.CreatedAt.ToString("dd MMM, HH:mm")</small>
                                        </div>
                                        <p class="mb-2 text-dark fw-medium">@msg.Content</p>
                                        <small class="text-muted"><i class="bi bi-person me-1"></i>Posted by @msg.CreatedBy</small>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-4">
                                <i class="bi bi-inbox text-muted fs-2 d-block mb-2"></i>
                                <p class="text-muted small mb-0">No new information messages.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
            
        </div>
        @if (User.IsInRole("Administrator"))
        {
            //total Revenue
            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm rounded-4 bg-primary text-white">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-white-50 text-uppercase small fw-bold">Total Revenue</h6>
                                    <h2 class="display-6 fw-bold mb-0">@Model.TotalRevenue.ToString("N2") €</h2>
                                </div>
                                <i class="bi bi-currency-euro fs-1 opacity-50"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="row g-4">

            @if (User.IsInRole("Administrator") || User.IsInRole("OrderManager"))
            {
                //MVP customers
                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-header bg-transparent border-0 pt-4 px-4">
                            <h5 class="fw-bold mb-0"><i class="bi bi-star text-warning me-2"></i>Top 5 Customers by Revenue</h5>
                        </div>
                        <div class="card-body px-4 pb-4">
                            <ul class="list-group list-group-flush">
                                @if (Model.TopCustomers.Any())
                                {
                                    @foreach (var customer in Model.TopCustomers)
                                    {
                                        <li class="list-group-item d-flex justify-content-between align-items-center border-0 px-0 py-3">
                                            <span class="text-dark fw-medium">@customer.Name</span>
                                            <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2">
                                                @customer.TotalSpent.ToString("N2") €
                                            </span>
                                        </li>
                                    }
                                }
                                else
                                {
                                    <li class="list-group-item border-0 px-0 py-3 text-muted text-center">No customer data available yet.</li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>

                //tracking order statuses
                <div class="col-xl-6 col-lg-7 mb-4">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-white py-3 d-flex align-items-center justify-content-between">
                            <h6 class="m-0 font-weight-bold text-primary text-uppercase" style="letter-spacing: 1px;">
                                <i class="bi bi-list-check me-2"></i>Order Fulfillment Status
                            </h6>
                            <span class="badge bg-light text-dark border">Total: @Model.TotalOrders</span>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-4">
                                    <div class="p-3 border-start border-success border-4 bg-light rounded">
                                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1" style="font-size: 0.75rem;">Shipped</div>
                                        <div class="h4 mb-0 font-weight-bold text-dark">@Model.ShippedOrdersCount</div>
                                    </div>
                                </div>
                    
                                <div class="col-4">
                                    <div class="p-3 border-start border-info border-4 bg-light rounded">
                                        <div class="text-xs font-weight-bold text-info text-uppercase mb-1" style="font-size: 0.75rem;">In Progress</div>
                                        <div class="h4 mb-0 font-weight-bold text-dark">@Model.InProgressOrdersCount</div>
                                    </div>
                                </div>
                    
                                <div class="col-4">
                                    <div class="p-3 border-start border-warning border-4 bg-light rounded">
                                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1" style="font-size: 0.75rem;">Processed</div>
                                        <div class="h4 mb-0 font-weight-bold text-dark">@Model.ProcessedOrdersCount</div>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-4">
                                <div class="progress" style="height: 8px; border-radius: 4px;">
                                    @{
                                        var total = Model.TotalOrders > 0 ? Model.TotalOrders : 1;
                                        var sPct = (Model.ShippedOrdersCount * 100.0) / total;
                                        var iPct = (Model.InProgressOrdersCount * 100.0) / total;
                                        var pPct = (Model.ProcessedOrdersCount * 100.0) / total;
                                    }
                                    <div class="progress-bar bg-success" style="width: @sPct%"></div>
                                    <div class="progress-bar bg-info" style="width: @iPct%"></div>
                                    <div class="progress-bar bg-warning" style="width: @pPct%"></div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 text-center pb-3">
                            <a asp-controller="Orders" asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                                Manage Orders <i class="bi bi-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            
            }

            @if (User.IsInRole("InventoryManager") || User.IsInRole("Administrator"))
            {
                //low Stock
                @if(@Model.LowStockProductsCount!=0)
                {<div class="col-md-3 mb-4">
                   
                        <div class="card text-white bg-warning shadow h-100">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <span><i class="bi bi-exclamation-triangle-fill"></i> Ниска наличност</span>
                            </div>
                            <div class="card-body">
                                <h3 class="card-title">@Model.LowStockProductsCount</h3>
                                <p class="card-text">Продукти с под 5 бройки в склада.</p>
                            </div>
                            <div class="card-footer bg-transparent border-0">
                                <a asp-controller="Products" asp-action="Index" class="text-white text-decoration-none fw-bold">
                                    Виж продуктите <i class="bi bi-arrow-right-circle"></i>
                                </a>
                            </div>
                        </div>
                </div>}

                //most purchased
                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100">
                        <div class="card-header bg-transparent border-0 pt-4 px-4">
                            <h5 class="fw-bold mb-0"><i class="bi bi-graph-up-arrow text-primary me-2"></i>Most Frequently Ordered Products</h5>
                        </div>
                        <div class="card-body px-4 pb-4">
                            <ul class="list-group list-group-flush">
                                @if (Model.MostPurchased.Any())
                                {
                                    @foreach (var product in Model.MostPurchased)
                                    {
                                        <li class="list-group-item border-0 px-0 py-3">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <span class="text-dark fw-medium">@product.ProductName</span>
                                                <span class="fw-bold text-primary">In @product.OrderCount orders</span>
                                            </div>
                                            <div class="progress mt-2" style="height: 6px;">
                                                <div class="progress-bar rounded-pill bg-primary opacity-75" style="width: 100%"></div>
                                            </div>
                                        </li>
                                    }
                                }
                                else
                                {
                                    <li class="list-group-item border-0 px-0 py-3 text-muted text-center">No product data available yet.</li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            }

        </div>
    </div>
}
else
{
    <div class="container py-5">
        <div class="row justify-content-center text-center">
            <div class="col-md-8">
                <h1 class="display-4 fw-bold text-dark mb-3">Streamline Your Inventory Management</h1>
                <p class="lead text-muted mb-5">
                    Access your dashboard to track shipping, fulfillments, and customer orders in real-time.
                    Please sign in to your account or register a new one to begin managing your warehouse stock.
                </p>

                <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                    <a asp-area="Identity" asp-page="/Account/Login"
                           class="btn btn-primary btn-lg px-5 shadow-sm rounded-3">
                        <i class="bi bi-box-arrow-in-right me-2"></i> Log In
                    </a>
                    <a asp-area="Identity" asp-page="/Account/Register"
                           class="btn btn-outline-primary btn-lg px-5 shadow-sm rounded-3">
                        <i class="bi bi-person-plus me-2"></i> Register
                    </a>
                </div>
            </div>
        </div>
    </div>
}