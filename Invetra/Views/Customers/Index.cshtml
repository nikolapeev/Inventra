@model IEnumerable<Inventra.Core.ViewModels.Customers.CustomerIndexViewModel>

@{
    ViewData["Title"] = "Customers";
}

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h1 class="h3 mb-1 text-dark fw-bold">Customers</h1>
        <p class="text-muted mb-0">Manage your client directory and contact details.</p>
        <form asp-action="Index" method="get" class="mb-3">
            <div class="input-group">
                <input type="text" name="searchTerm" value="@ViewBag.CurrentSearch"
                       class="form-control" />
                <button type="submit" class="btn btn-outline-secondary">
                    <i class="bi bi-search"></i> Search
                </button>
                <a asp-action="Index" class="btn btn-outline-danger">Clear</a>
            </div>
        </form>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-primary shadow-sm rounded-3">
            <i class="bi bi-person-plus me-1"></i> Add Customer
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="py-3">Company name</th>
                        <th class="ps-4 py-3">Representative Name</th>
                        <th class="py-3">Email</th>
                        <th class="py-3">Phone</th>
                        <th class="text-end pe-4 py-3" style="width: 15%;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-people fs-2 d-block mb-2"></i>
                                No customers found. Click "Add Customer" to add your first client.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-info bg-opacity-10 text-info rounded d-flex justify-content-center align-items-center me-3" style="width: 35px; height: 35px;">
                                            <i class="bi bi-person-fill"></i>
                                        </div>
                                        @Html.DisplayFor(modelItem => item.CompanyName)
                                    </div>
                                </td>
                                <td class="py-3 text-muted">
                                    <span class="text-truncate d-inline-block" style="max-width: 250px;">
                                        @Html.DisplayFor(modelItem => item.FullName)
                                    </span>
                                </td>
                                <td class="py-3 text-muted">
                                    <a href="mailto:@item.Email" class="text-decoration-none">@Html.DisplayFor(modelItem => item.Email)</a>
                                </td>
                                <td class="py-3 text-muted">
                                    <i class="bi bi-telephone text-secondary me-1"></i> @Html.DisplayFor(modelItem => item.PhoneNumber)
                                </td>
                                <td class="text-end pe-4 py-3">
                                    <div class="btn-group btn-group-sm shadow-sm" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.CustomerId" class="btn btn-outline-primary" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.CustomerId" class="btn btn-outline-secondary" title="Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.CustomerId" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this customer?');">
                                            <button type="submit" class="btn btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>