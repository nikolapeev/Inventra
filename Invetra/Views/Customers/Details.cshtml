@model Inventra.Core.ViewModels.Customers.CustomerDetailsViewModel

@{
    ViewData["Title"] = "Customer Profile";
}

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <a asp-action="Index" class="text-decoration-none text-muted mb-2 d-inline-block">
            <i class="bi bi-arrow-left me-1"></i> Back to Customers
        </a>
        <h1 class="h3 text-dark fw-bold">Customer Profile</h1>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.CustomerId" class="btn btn-primary shadow-sm rounded-3">
            <i class="bi bi-pencil me-1"></i> Edit Profile
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-5">
        <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
            <div class="card-body p-4 text-center border-bottom">
                <div class="bg-info bg-opacity-10 text-info rounded-circle d-inline-flex justify-content-center align-items-center mb-3" style="width: 80px; height: 80px;">
                    <i class="bi bi-person-fill" style="font-size: 2.5rem;"></i>
                </div>
                <h4 class="fw-bold text-dark mb-1">@Html.DisplayFor(model => model.FullName)</h4>
                <p class="text-muted mb-0">@Html.DisplayFor(model => model.CompanyName)</p>
                
                @if (Model.ZDDS)
                {
                    <span class="badge bg-success rounded-pill mt-2 px-3 py-2 shadow-sm"><i class="bi bi-check-circle me-1"></i> VAT Registered</span>
                }
                else
                {
                    <span class="badge bg-secondary rounded-pill mt-2 px-3 py-2 shadow-sm">Non-VAT</span>
                }
            </div>
            <div class="card-body p-4">
                <h6 class="text-uppercase text-muted fw-bold mb-3 fs-7" style="letter-spacing: 1px;">Contact Details</h6>
                <div class="mb-3 d-flex align-items-center">
                    <div class="bg-light rounded p-2 me-3 text-secondary"><i class="bi bi-envelope"></i></div>
                    <div>
                        <small class="d-block text-muted">Email</small>
                        <a href="mailto:@Model.Email" class="text-dark text-decoration-none fw-bold">@Html.DisplayFor(model => model.Email)</a>
                    </div>
                </div>
                <div class="mb-3 d-flex align-items-center">
                    <div class="bg-light rounded p-2 me-3 text-secondary"><i class="bi bi-telephone"></i></div>
                    <div>
                        <small class="d-block text-muted">Phone</small>
                        <span class="text-dark fw-bold">@Html.DisplayFor(model => model.PhoneNumber)</span>
                    </div>
                </div>
                <div class="d-flex align-items-center">
                    <div class="bg-light rounded p-2 me-3 text-secondary"><i class="bi bi-briefcase"></i></div>
                    <div>
                        <small class="d-block text-muted">EIK / Company ID</small>
                        <span class="text-dark fw-bold">@Html.DisplayFor(model => model.EIK)</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-7">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-white border-bottom py-3 px-4">
                <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-geo-alt text-primary me-2"></i>Location & Shipping Details</h5>
            </div>
            <div class="card-body p-4">
                <dl class="row mb-0 g-3">
                    <dt class="col-sm-4 text-muted fw-normal">Street Address</dt>
                    <dd class="col-sm-8 fw-bold text-dark">@Html.DisplayFor(model => model.Address)</dd>
                    
                    <div class="col-12"><hr class="my-1 border-light"></div>

                    <dt class="col-sm-4 text-muted fw-normal">City</dt>
                    <dd class="col-sm-8 fw-bold text-dark">@Html.DisplayFor(model => model.City)</dd>
                    
                    <div class="col-12"><hr class="my-1 border-light"></div>

                    <dt class="col-sm-4 text-muted fw-normal">County / Province</dt>
                    <dd class="col-sm-8 fw-bold text-dark">@Html.DisplayFor(model => model.County)</dd>
                    
                    <div class="col-12"><hr class="my-1 border-light"></div>

                    <dt class="col-sm-4 text-muted fw-normal">Country</dt>
                    <dd class="col-sm-8 fw-bold text-dark">@Html.DisplayFor(model => model.Country)</dd>
                    
                    <div class="col-12"><hr class="my-1 border-light"></div>

                    <dt class="col-sm-4 text-muted fw-normal">Postal Code</dt>
                    <dd class="col-sm-8 fw-bold text-dark">@Html.DisplayFor(model => model.PostalCode)</dd>
                </dl>
            </div>
        </div>
    </div>
</div>