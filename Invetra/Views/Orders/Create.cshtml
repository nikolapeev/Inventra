@model Inventra.Core.ViewModels.Orders.OrderCreateViewModel

@{
    ViewData["Title"] = "Create Order";
}

<h1>Create Order</h1>

<h4>New Order</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="CustomerId" class="control-label">Customer</label>
                <select asp-for="CustomerId" class="form-control" asp-items="ViewBag.CustomerId">
                    <option value="">-- Select Customer --</option>
                </select>
                <span asp-validation-for="CustomerId" class="text-danger"></span>

            </div>

            <div class="form-group mb-3">
                <label asp-for="CourierId" class="control-label">Assign Courier</label>
                <select asp-for="CourierId" class="form-control" asp-items="ViewBag.CourierId">
                    <option value="">-- Select Courier --</option>
                </select>
                <span asp-validation-for="CourierId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="TrackingNumber" class="control-label"></label>
                <input asp-for="TrackingNumber" class="form-control" placeholder="Enter tracking number" />
                <span asp-validation-for="TrackingNumber" class="text-danger"></span>
            </div>

            @* <div class="form-group mb-3">
                <label asp-for="TotalPrice" class="control-label"></label>
                <input asp-for="TotalPrice" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="TotalPrice" class="text-danger"></span>
            </div> *@

            @* Matches the AdditionalInfo field in your Controller mapping *@
            <div class="form-group mb-3">
                <label asp-for="AdditionalInfo" class="control-label"></label>
                <textarea asp-for="AdditionalInfo" class="form-control" rows="3" placeholder="Notes about the delivery..."></textarea>
                <span asp-validation-for="AdditionalInfo" class="text-danger"></span>
            </div>

            <div class="form-group mt-4">
                <input type="submit" value="Create Order" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}