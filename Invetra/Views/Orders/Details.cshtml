@model Inventra.Core.ViewModels.Orders.OrderDetailsViewModel

@{
    ViewData["Title"] = "Order Details";
}

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <a asp-action="Index" class="text-decoration-none text-muted mb-2 d-inline-block">
            <i class="bi bi-arrow-left me-1"></i> Back to Orders
        </a>
        <h1 class="h3 text-dark fw-bold">Order Details</h1>
    </div>
</div>

<div class="row g-4 mb-4">

    <div class="col-xl-4 col-lg-5">
        <div class="card border-0 shadow-sm rounded-4 h-100 border-start border-success border-4">
            <div class="card-body p-4 d-flex flex-column justify-content-center">
                <div class="text-xs fw-bold text-success text-uppercase mb-1">Order Total</div>
                <div class="h2 mb-0 fw-bold text-dark">@Model.TotalPrice.ToString("N2") €</div>
                <div class="mt-3">
                    <span class="badge bg-light text-dark border"><i class="bi bi-upc-scan me-1"></i> @Model.TrackingNumber</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-8 col-lg-7">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-4">
                <dl class="row mb-0 g-3">
                    <dt class="col-sm-4 text-muted fw-normal"><i class="bi bi-person me-2 text-primary"></i>Customer</dt>
                    <dd class="col-sm-8 fw-bold text-dark">
                        @Model.CustomerName |
                        <a href="mailto:@Model.Email" class="text-decoration-none">@Model.Email</a> |
                        @Model.Phone
                    </dd>
                    
                    <div class="col-12"><hr class="my-1 border-light"></div>

                    <dt class="col-sm-4 text-muted fw-normal"><i class="bi bi-building me-2 text-primary"></i>Company</dt>
                    <dd class="col-sm-8 fw-bold text-dark">@Model.CompanyName</dd>

                    <div class="col-12"><hr class="my-1 border-light"></div>

                    <dt class="col-sm-4 text-muted fw-normal"><i class="bi bi-bicycle me-2 text-primary"></i>Courier</dt>
                    <dd class="col-sm-8 fw-bold text-dark">@Model.CourierName</dd>
                    
                    <div class="col-12"><hr class="my-1 border-light"></div>

                    <dt class="col-sm-4 text-muted fw-normal"><i class="bi bi-info-circle me-2 text-primary"></i>Additional Info</dt>
                    <dd class="col-sm-8 text-dark mb-0">@Model.AdditionalInfo</dd>
                </dl>
            </div>
        </div>
    </div>
</div>


<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-header bg-white border-bottom py-3 px-4 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-box-seam text-primary me-2"></i>Products in this Order</h5>
        <button type="button" class="btn btn-primary btn-sm rounded-3 shadow-sm px-3" onclick="openAddProductModal('@Model.Id')">
            <i class="bi bi-plus-lg me-1"></i> Add Product
        </button>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4 py-3">Product Name</th>
                        <th class="text-end py-3">Quantity</th>
                        <th class="text-end py-3">Unit Price</th>
                        <th class="text-end py-3">Subtotal</th>
                        <th class="text-end py-3">Subtotal + VAT</th>
                        <th class="text-end pe-4 py-3" style="width: 15%;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Products != null && Model.Products.Count > 0)
                    {
                        @foreach (Inventra.Data.Entities.OrderDetails item in Model.Products)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary bg-opacity-10 text-primary rounded d-flex justify-content-center align-items-center me-3" style="width: 35px; height: 35px;">
                                            <i class="bi bi-box"></i>
                                        </div>
                                        @item.Product?.Name
                                    </div>
                                </td>
                                <td class="text-end fw-bold text-dark py-3">
                                    <span class="badge bg-light text-dark border px-2 py-1 fs-6">@item.QTY</span>
                                </td>
                                <td class="text-end text-muted py-3">
                                    @item.Product.Price.ToString("N2") €
                                </td>
                                <td class="text-end fw-bold text-success py-3">
                                    @item.Subtotal.ToString("N2") €
                                </td>
                                <td class="text-end text-muted py-3">
                                    @Decimal.Multiply(item.Subtotal,(decimal)1.2).ToString("N2") €
                                </td>
                                <td class="text-end pe-4 py-3">
                                    <div class="btn-group btn-group-sm shadow-sm" role="group">
                                        <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editModal-@item.OrderId-@item.ProductId" title="Edit Quantity">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                       
                                        <form asp-controller="OrderDetails" asp-action="Delete" method="post" asp-route-orderId="@item.OrderId" asp-route-productId="@item.ProductId" class="d-inline" onsubmit="return confirm('Are you sure you want to completely remove this product from the order?');">
                                            <button type="submit" class="btn btn-outline-danger" title="Remove Product">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-cart-x fs-2 d-block mb-2"></i>
                                <em>No products have been added to this order yet.</em>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>


@if (Model.Products != null && Model.Products.Count > 0)
{
    @foreach (Inventra.Data.Entities.OrderDetails item in Model.Products)
    {
        <div class="modal fade" id="editModal-@item.OrderId-@item.ProductId" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow rounded-4">
                    <div class="modal-header border-bottom-0 pb-0">
                        <h5 class="modal-title fw-bold text-dark">Update Quantity</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    
                    <form asp-controller="OrderDetails" asp-action="Edit" method="post">
                        <div class="modal-body py-4">
                            <p class="text-muted small mb-3">Updating stock allocation for <strong>@item.Product?.Name</strong></p>

                            <input type="hidden" name="OrderId" value="@item.OrderId" />
                            <input type="hidden" name="ProductId" value="@item.ProductId" />
                            
                            <div class="mb-2">
                                <label class="form-label fw-bold text-dark">New Quantity <span class="text-danger">*</span></label>
                                <div class="input-group input-group-lg shadow-sm rounded-3">
                                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-123"></i></span>
                                    <input type="number" name="QTY" class="form-control border-start-0 ps-0" value="@item.QTY" min="1" required />
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer border-top-0 pt-0">
                            <button type="button" class="btn btn-light rounded-3 px-4" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary rounded-3 px-4 shadow-sm"><i class="bi bi-check-lg me-1"></i> Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
}


<div class="modal fade" id="addProductModal" tabindex="-1" aria-labelledby="addProductModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4" id="addProductModalContent">
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openAddProductModal(orderId) {
            $.get('/OrderDetails/Create', { orderId: orderId }, function(data) {
                $('#addProductModalContent').html(data);
                var addModal = new bootstrap.Modal(document.getElementById('addProductModal'));
                addModal.show();
            }).fail(function() {
                alert("Възникна грешка при зареждането на формата. Моля, проверете връзката или опитайте отново.");
            });
        }
    </script>
}