@model Inventra.Models.Orders.OrderDetailsViewModel

@{
    ViewData["Title"] = "Order Details";
}

<div class="container mt-4">
    <h1>Details</h1>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Order Information</h4>
        </div>
        <div class="card-body">
            <hr />
            <dl class="row">
                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.CustomerName)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.CustomerName)
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.CourierName)
                </dt>
                <dd class="col-sm-9">
                    @if (string.IsNullOrEmpty(Model.CourierName))
                    {
                        <span class="text-muted italic">No courier assigned</span>
                    }
                    else
                    {
                        @Html.DisplayFor(model => model.CourierName)
                    }
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.TrackingNumber)
                </dt>
                <dd class="col-sm-9 text-monospace">
                    @Html.DisplayFor(model => model.TrackingNumber)
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.TotalPrice)
                </dt>
                <dd class="col-sm-9 fw-bold text-success">
                    @Model.TotalPrice.ToString("C")
                </dd>

                @if (!string.IsNullOrEmpty(Model.AdditionalInfo))
                {
                    <dt class="col-sm-3">
                        @Html.DisplayNameFor(model => model.AdditionalInfo)
                    </dt>
                    <dd class="col-sm-9">
                        @Html.DisplayFor(model => model.AdditionalInfo)
                    </dd>
                }
            </dl>
        </div>
        <div class="card-footer bg-light">
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">Edit Order</a>
            <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
        </div>
    </div>
</div>
