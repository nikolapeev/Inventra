@model IEnumerable<Inventra.Data.Entities.InventraUser>
@using Inventra.Controllers
@using Microsoft.AspNetCore.Identity
@inject UserManager<Inventra.Data.Entities.InventraUser> userManager

@{
    ViewData["Title"] = "Управление на достъпа";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h1 class="h3 mb-1 text-dark fw-bold">Управление на достъпа</h1>
        <p class="text-muted mb-0">Manage user roles and system access.</p>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4 py-3">Потребител</th>
                        <th class="py-3">Current Role</th>
                        <th class="text-end pe-4 py-3">Действия (Дай роля)</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5 text-muted">
                                <i class="bi bi-people fs-2 d-block mb-2"></i>
                                No users found in the system.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-secondary bg-opacity-10 text-secondary rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 40px; height: 40px;">
                                            <i class="bi bi-person"></i>
                                        </div>
                                        @user.Email
                                    </div>
                                </td>

                                <td class="py-3">
                                    @{
                                        var roles = await userManager.GetRolesAsync(user);
                                    }
                                    @if (!roles.Any())
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill px-3 py-1">
                                            Not Authorized
                                        </span>
                                    }
                                    else
                                    {
                                        @foreach (var role in roles)
                                        {
                                            var badgeColor = role == "Administrator" ? "danger" :
                                                             role == "InventoryManager" ? "primary" : "success";
                                            
                                            <span class="badge bg-@badgeColor bg-opacity-10 text-@badgeColor border border-@badgeColor border-opacity-25 rounded-pill px-3 py-1 me-1 mb-1">
                                                @role
                                            </span>
                                        }
                                    }
                                </td>

                                <td class="text-end pe-4 py-3">
                                    <div class="d-flex justify-content-end align-items-center gap-2">
                                        
                                        <form asp-action="AssignRole" method="post" class="m-0 d-flex gap-1">
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            
                                            <button name="roleName" value="Administrator" class="btn btn-sm btn-outline-danger shadow-sm" title="Assign Administrator">
                                                <i class="bi bi-shield-lock me-1"></i> Admin
                                            </button>
                                            <button name="roleName" value="InventoryManager" class="btn btn-sm btn-outline-primary shadow-sm" title="Assign Inventory Manager">
                                                <i class="bi bi-boxes me-1"></i> Inventory
                                            </button>
                                            <button name="roleName" value="OrderManager" class="btn btn-sm btn-outline-success shadow-sm" title="Assign Order Manager">
                                                <i class="bi bi-cart-check me-1"></i> Orders
                                            </button>
                                        </form>

                                        <div class="vr mx-1 text-muted"></div>

                                        <form asp-action="DeleteUser" method="post" class="m-0" onsubmit="return confirm('Are you sure you want to permanently delete this user?');">
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <button class="btn btn-sm btn-danger shadow-sm" title="Delete User">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
}